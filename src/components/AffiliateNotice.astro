---
/* src/components/AffiliateNotice.astro */
---
<div class="affiliate-disclosure">
  <strong>Disclosure:</strong> Prefrontal Profit is a systems directory. We may earn a commission if you open an account through our links. This supports our technical research for the trading community at no extra cost to you.
</div>

<style>
  .affiliate-disclosure {
    font-size: 0.8rem;
    font-style: italic;
    color: #718096;
    border-top: 1px solid #2d3748;
    border-bottom: 1px solid #2d3748;
    padding: 10px 0;
    margin: 1.5rem 0;
    display: block;
    line-height: 1.5;
  }
  .affiliate-disclosure strong {
    color: #48bb78;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
  }
</style>
