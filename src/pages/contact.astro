---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'Contact Us', template: 'splash' }}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 gap-12 items-start">
      
      <div>
        <h2 class="text-3xl font-bold text-white mb-6">Get in Touch</h2>
        <p class="text-gray-300 text-lg mb-8 leading-relaxed">
          Have a query about our systems directory or interested in a strategic partnership? 
          Connect with the <strong>Prefrontal Profit</strong> team directly.
        </p>
        
        <div class="space-y-6">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-green-400">Email</h3>
            <p class="text-white text-xl">contact@prefrontalprofit.com</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-green-400">Location</h3>
            <p class="text-white text-lg">Mumbai, India</p>
          </div>
        </div>
      </div>

      <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl shadow-xl">
        <form action="https://formspree.io/f/xjgaogvy" method="POST" class="flex flex-col gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-400 mb-1">Full Name</label>
            <input type="text" id="name" name="name" required 
              class="w-full bg-slate-800 border border-slate-700 text-white rounded-lg p-3 focus:ring-2 focus:ring-green-500 outline-none transition-all" />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-400 mb-1">Work Email</label>
            <input type="email" id="email" name="email" required 
              class="w-full bg-slate-800 border border-slate-700 text-white rounded-lg p-3 focus:ring-2 focus:ring-green-500 outline-none transition-all" />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-400 mb-1">Message</label>
            <textarea id="message" name="message" rows="4" required 
              class="w-full bg-slate-800 border border-slate-700 text-white rounded-lg p-3 focus:ring-2 focus:ring-green-500 outline-none transition-all"></textarea>
          </div>
          
          <button type="submit" 
            class="w-full bg-green-500 hover:bg-green-400 text-black font-bold py-4 rounded-lg transition-transform active:scale-95 shadow-lg">
            Send Message
          </button>
        </form>
      </div>

    </div>
  </div>
</StarlightPage>

<style>
  :root {
    --sl-color-bg: #0f172a; /* Dark navy background matching Starlight */
  }
</style>