---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---
<StarlightPage frontmatter={{ title: 'Privacy Policy', template: 'splash' }}>
  <div class="max-w-4xl mx-auto px-4 py-10 text-gray-300">
    <p class="mb-4">Last Updated: March 2026</p>
    <h2 class="text-white text-2xl font-bold mb-4">1. Information We Collect</h2>
    <p class="mb-6">We collect minimal data through our contact forms (Name, Email) solely for partnership communication. We do not sell or share this data with third parties.</p>
    <h2 class="text-white text-2xl font-bold mb-4">2. Cookies & Analytics</h2>
    <p class="mb-6">We use industry-standard analytics to understand how users interact with our broker comparisons to improve our directory accuracy.</p>
    <h2 class="text-white text-2xl font-bold mb-4">3. External Links</h2>
    <p class="mb-6">Prefrontal Profit contains links to external brokerages (e.g., Dhan, Upstox). We are not responsible for the privacy practices of these external entities.</p>
  </div>
</StarlightPage>